# ---- MemoryMate frontend environment ----
# Copy this file to ".env" and adjust values.

# Base URL of the backend API (no trailing slash). The app calls `${REACT_APP_BACKEND_URL}/api`.
REACT_APP_BACKEND_URL=http://localhost:8000

# Optional: show WHOOP connector UI (planning only — not a live integration).
# REACT_APP_WHOOP_CONNECTOR_ENABLED=false

# Optional: port for the dev server (defaults to 3000).
# PORT=3002
