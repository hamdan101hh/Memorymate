# ---- MemoryMate backend environment ----
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.

# MongoDB connection. Local dev example shown; for production use a MongoDB Atlas URI.
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=memorymate

# Secret used to sign JWTs. Generate a strong random value, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed frontend origins (CORS).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Seeded admin account (optional overrides).
ADMIN_EMAIL=admin@memorymate.app
ADMIN_PASSWORD=admin123

# ---- AI provider key (choose ONE) ----
# The AI layer auto-detects which key is present, in this order:
#   1) EMERGENT_LLM_KEY  -> Anthropic Claude Sonnet 4.6 via Emergent's universal key
#   2) ANTHROPIC_API_KEY -> Anthropic Claude Sonnet 4.6 (sk-ant-...)
#   3) OPENAI_API_KEY    -> OpenAI (gpt-4o-mini); also enables Whisper audio transcription
# If none is set, all AI features degrade gracefully (no crashes) and just return
# calm fallback messages. Audio transcription needs OPENAI_API_KEY or EMERGENT_LLM_KEY.
EMERGENT_LLM_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Optional: override the model name for the selected provider.
# MODEL_NAME=claude-sonnet-4-6
