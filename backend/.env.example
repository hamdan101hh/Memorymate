# ---- MemoryMate backend environment ----
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.

# MongoDB connection. Local dev example shown; for production use a MongoDB Atlas URI.
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=memorymate

# Secret used to sign JWTs. Generate a strong random value, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed frontend origins (CORS).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Seeded admin account (optional overrides).
ADMIN_EMAIL=admin@memorymate.app
ADMIN_PASSWORD=admin123

# Demo mode: when "true" (default) the app seeds demo accounts and exposes
# /api/auth/demo-login (sign in as any role WITHOUT a password) — handy for
# showcasing. Set to "false" in production so only real registered users get in.
ENABLE_DEMO=true

# ---- AI provider key (choose ONE) ----
# The AI layer auto-detects which key is present, in this order:
#   1) EMERGENT_LLM_KEY  -> Anthropic Claude Sonnet 4.6 via Emergent's universal key
#   2) ANTHROPIC_API_KEY -> Anthropic Claude Sonnet 4.6 (sk-ant-...)
#   3) OPENAI_API_KEY    -> OpenAI (gpt-4o-mini); also enables Whisper audio transcription
# If none is set, all AI features degrade gracefully (no crashes) and just return
# calm fallback messages. Audio transcription needs OPENAI_API_KEY or EMERGENT_LLM_KEY.
EMERGENT_LLM_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Optional: override the model name for the selected provider.
# MODEL_NAME=claude-sonnet-4-6

# ---- Cost controls (for always-on / 24-7 capture) ----
# High-VOLUME work (capture filtering, meeting & memory summaries) can run on a
# cheaper model so always-on capture stays affordable. Interactive work (the
# assistant) keeps the primary model. Defaults to the primary model if unset.
# Recommended cheap tier: provider "openai" + "gpt-4o-mini".
# CAPTURE_MODEL_PROVIDER=openai
# CAPTURE_MODEL_NAME=gpt-4o-mini
#
# Hard daily AI cost ceiling PER PATIENT (USD). Once hit, AI calls are refused for
# the rest of the day (the rest of the app keeps working). Set 0 to disable.
# DAILY_AI_COST_CAP_USD=0.50
#
# ---- Voice / transcription cost guardrails ----
# CLOUD_TRANSCRIPTION_ENABLED=false
# VOICE_COST_GUARDRAILS_ENABLED=true
# REQUIRE_CONFIRMATION_FOR_CLOUD_TRANSCRIPTION=true
# FREE_VOICE_MINUTES_PER_DAY=5
# PLUS_VOICE_MINUTES_PER_DAY=30
# FAMILY_VOICE_MINUTES_PER_DAY=60
# DEFAULT_VOICE_MINUTES_PER_DAY=15
# MAX_SINGLE_RECORDING_MINUTES=10
# MAX_MEETING_CAPTURE_MINUTES=60
#
# ---- AI provider pipeline (cost-safe defaults) ----
# TEXT_AI_PROVIDER=rule_based
# CHEAP_TEXT_AI_PROVIDER=deepseek
# PREMIUM_TEXT_AI_PROVIDER=gemini_or_openai
# PREMIUM_FALLBACK_ENABLED=false
# MAX_AI_PROVIDERS_PER_REQUEST=1
# ALLOW_PREMIUM_RETRY=false
# DAILY_VOICE_MINUTES_CAP=5
# MAX_AI_ACTIONS_PER_DAY=50
# MAX_RECORDING_SECONDS=600
# MAX_MEETING_MINUTES=60
# SMART_DAY_CLOUD_MINUTES_CAP=15
# MAX_SMART_DAY_SNIPPET_SECONDS=60
# MAX_SMART_DAY_SESSION_HOURS=2
#
# ---- Premium feature flags (default OFF — no paid APIs until approved) ----
# FOCUS_CAPTURE_ENABLED=false
# WHATSAPP_ASSISTANT_ENABLED=false
# MONTHLY_SUMMARY_ENABLED=false
# CLOUD_TRANSCRIPTION_ENABLED=false
# PAID_AI_ENABLED=false
# AUTO_TOP_UP_ENABLED=false
# GLOBAL_MONTHLY_BUDGET_USD=100
# TARGET_SUBSCRIPTION_PRICE_USD=10
# INTERNAL_COST_TARGET_PER_USER_USD=1.0
# FREE_TRIAL_DAYS=3
# MONTHLY_USAGE_QUOTA_ENFORCED=false   # set true in production after quotas configured

# ---- WhatsApp bot (Meta Cloud API) ----
# Inbound messages are saved as memories; outbound sends reminders/summaries.
# Requires a deployed public URL for Meta's webhook. Leave blank to disable.
# WHATSAPP_VERIFY_TOKEN=pick-any-string-and-paste-into-meta
# WHATSAPP_ACCESS_TOKEN=EAAB...           # Graph API token (System User recommended)
# WHATSAPP_PHONE_NUMBER_ID=123456789012345
# WHATSAPP_APP_SECRET=                     # optional: verifies webhook signatures
# WHATSAPP_REMINDER_TEMPLATE=             # optional: approved template for proactive reminders
# WHATSAPP_TEMPLATE_LANG=en_US
# CRON_SECRET=                             # optional: protects the due-reminders + notifications cron

# ---- Web Push notifications (VAPID) ----
# Browser/PWA push for reminders, caregiver alerts, daily summary & privacy review.
# Generate a keypair once with:
#   python3 -c "from py_vapid import Vapid01; import base64; from cryptography.hazmat.primitives import serialization as s; \
#     v=Vapid01(); v.generate_keys(); b=lambda x: base64.urlsafe_b64encode(x).rstrip(b'=').decode(); \
#     print('VAPID_PUBLIC_KEY='+b(v.public_key.public_bytes(s.Encoding.X962, s.PublicFormat.UncompressedPoint))); \
#     print('VAPID_PRIVATE_KEY='+b(v.private_key.private_numbers().private_value.to_bytes(32,'big')))"
# Leave blank to disable push entirely (the app degrades gracefully to WhatsApp/in-app).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@yourdomain.com   # contact for push services (required by some)

# Deployment environment. Set to "production" on real deployments. In production,
# secrets like Google OAuth tokens REQUIRE TOKEN_ENCRYPTION_KEY (the calendar
# connect flow fails safely if it is missing). In dev a fallback key is derived
# from JWT_SECRET with a warning. (ENABLE_DEMO=false is also treated as production.)
# ENVIRONMENT=development

# ---- Google Calendar connector ----
# Privacy-first: reads events only after the user connects, imports/adds only after
# approval, and never edits or deletes events. Create an OAuth client (Web app) in
# Google Cloud console; add the redirect URI below to its authorized list.
# Leave blank to disable the connector (it degrades gracefully).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/callback
# FRONTEND_URL=http://localhost:3000        # where users return after consent
# CAL_TIMEZONE=UTC                          # fallback tz when a patient has none set
#
# Encrypts Google OAuth access/refresh tokens at rest (Fernet). Any string works
# (it's hashed to a key). REQUIRED in production. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# TOKEN_ENCRYPTION_KEY=

# ---- Photo / image attachments (local dev storage) ----
# Files live under backend/uploads/patient_images/ on the API server.
# Render free tier disk is ephemeral — production blocks uploads by default until
# private persistent storage is configured.
#
# IMAGE_UPLOADS_ENABLED — default: true in local dev, false in production
# IMAGE_STORAGE_MODE — local_dev | disabled | private_object_storage (future)
#   default: local_dev in dev, disabled in production
# ALLOW_LOCAL_IMAGE_STORAGE_IN_PRODUCTION — default false; only set true for
#   intentional short-lived testing on ephemeral disk (not for real users)
#
# Do NOT use Google Cloud Storage unless explicitly approved.
# Do NOT enable Google Photos API, Google Vision API, or paid OCR/image AI.
# MAX_IMAGE_BYTES=5242880
# MAX_IMAGES_PER_NOTE=3
