# ---- MemoryMate backend environment ----
# Copy this file to ".env" and fill in real values. NEVER commit the real .env.

# MongoDB connection. Local dev example shown; for production use a MongoDB Atlas URI.
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=memorymate

# Secret used to sign JWTs. Generate a strong random value, e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed frontend origins (CORS).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Seeded admin account (optional overrides).
ADMIN_EMAIL=admin@memorymate.app
ADMIN_PASSWORD=admin123

# Demo mode: when "true" (default) the app seeds demo accounts and exposes
# /api/auth/demo-login (sign in as any role WITHOUT a password) — handy for
# showcasing. Set to "false" in production so only real registered users get in.
ENABLE_DEMO=true

# ---- AI provider key (choose ONE) ----
# The AI layer auto-detects which key is present, in this order:
#   1) EMERGENT_LLM_KEY  -> Anthropic Claude Sonnet 4.6 via Emergent's universal key
#   2) ANTHROPIC_API_KEY -> Anthropic Claude Sonnet 4.6 (sk-ant-...)
#   3) OPENAI_API_KEY    -> OpenAI (gpt-4o-mini); also enables Whisper audio transcription
# If none is set, all AI features degrade gracefully (no crashes) and just return
# calm fallback messages. Audio transcription needs OPENAI_API_KEY or EMERGENT_LLM_KEY.
EMERGENT_LLM_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Optional: override the model name for the selected provider.
# MODEL_NAME=claude-sonnet-4-6

# ---- Cost controls (for always-on / 24-7 capture) ----
# High-VOLUME work (capture filtering, meeting & memory summaries) can run on a
# cheaper model so always-on capture stays affordable. Interactive work (the
# assistant) keeps the primary model. Defaults to the primary model if unset.
# Recommended cheap tier: provider "openai" + "gpt-4o-mini".
# CAPTURE_MODEL_PROVIDER=openai
# CAPTURE_MODEL_NAME=gpt-4o-mini
#
# Hard daily AI cost ceiling PER PATIENT (USD). Once hit, AI calls are refused for
# the rest of the day (the rest of the app keeps working). Set 0 to disable.
# DAILY_AI_COST_CAP_USD=0.50

# ---- WhatsApp bot (Meta Cloud API) ----
# Inbound messages are saved as memories; outbound sends reminders/summaries.
# Requires a deployed public URL for Meta's webhook. Leave blank to disable.
# WHATSAPP_VERIFY_TOKEN=pick-any-string-and-paste-into-meta
# WHATSAPP_ACCESS_TOKEN=EAAB...           # Graph API token (System User recommended)
# WHATSAPP_PHONE_NUMBER_ID=123456789012345
# WHATSAPP_APP_SECRET=                     # optional: verifies webhook signatures
# WHATSAPP_REMINDER_TEMPLATE=             # optional: approved template for proactive reminders
# WHATSAPP_TEMPLATE_LANG=en_US
# CRON_SECRET=                             # optional: protects the due-reminders cron endpoint
